# ============================================
# AI Legion - 模型 API 密钥配置
# 复制此文件为 .env 并填入您的密钥
# ============================================

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GOOGLE_API_KEY=xxx
GOOGLE_MODEL=gemini-2.0-flash

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============================================
# 引擎配置
# ============================================

# 聚合策略: vote | best_of | chain | cascade
STRATEGY=vote

# API 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ============================================
# API 认证 (留空则不启用认证，适合开发调试)
# ============================================
API_TOKEN=